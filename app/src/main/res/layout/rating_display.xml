<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/customer_stars_on_rating"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_margin="8dp"
    android:background="@android:color/white"
    android:elevation="2dp">

    <!-- Top Row: Name + Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/customer_name_on_rating"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Customer Name"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/date_on_left_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="04/11/2026"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Stars -->
    <RatingBar
        android:id="@+id/stars_left_on_review"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.5"
        android:isIndicator="true"
        android:layout_marginTop="6dp"/>

    <!-- Comment -->
    <TextView
        android:id="@+id/customer_comment_on_rating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This service was great!"
        android:layout_marginTop="8dp"
        android:textSize="14sp"/>

</LinearLayout>